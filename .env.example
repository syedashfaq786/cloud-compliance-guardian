# AWS Credentials — Get these from IAM > Users > Security Credentials > Create Access Key
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# Sec-8B Model Endpoint
SEC8B_ENDPOINT=http://localhost:11434
SEC8B_MODEL=cisco-sec-8b
SEC8B_BACKEND=ollama
